{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conflictcraft.dev/schemas/suggestion.schema.json",
  "title": "Suggestion",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "hunk_id",
    "rule_id",
    "action",
    "resolved_lines",
    "confidence",
    "safe_to_apply",
    "deterministic_hash"
  ],
  "properties": {
    "hunk_id": { "type": "string" },
    "rule_id": { "type": "string" },
    "action": {
      "type": "string",
      "enum": ["keep_ours", "keep_theirs", "combine", "manual_required"]
    },
    "resolved_lines": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "safe_to_apply": { "type": "boolean" },
    "deterministic_hash": { "type": "string", "minLength": 8 },
    "notes": { "type": "string" }
  }
}
