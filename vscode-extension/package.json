{
  "name": "conflictcraft-vscode",
  "displayName": "ConflictCraft",
  "description": "Visual and explainable Git conflict resolution",
  "version": "0.2.1",
  "publisher": "infiniware",
  "icon": "assets/conflictcraft-logo.png",
  "keywords": [
    "git",
    "merge",
    "conflict",
    "resolution",
    "diff3",
    "vscode"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:conflictcraft.openEditor",
    "onCommand:conflictcraft.resolveCurrentFile",
    "onCommand:conflictcraft.runDoctor",
    "onCommand:conflictcraft.scanWorkspaceConflicts",
    "onCommand:conflictcraft.resolveGitUnmerged",
    "onCommand:conflictcraft.openFullTutorial",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "conflictcraft.openEditor",
        "title": "ConflictCraft: Open Editor"
      },
      {
        "command": "conflictcraft.resolveCurrentFile",
        "title": "ConflictCraft: Resolve Current File"
      },
      {
        "command": "conflictcraft.toggleExplainMode",
        "title": "ConflictCraft: Toggle Explain Mode"
      },
      {
        "command": "conflictcraft.undoAction",
        "title": "ConflictCraft: Undo Action"
      },
      {
        "command": "conflictcraft.redoAction",
        "title": "ConflictCraft: Redo Action"
      },
      {
        "command": "conflictcraft.runDoctor",
        "title": "ConflictCraft: Run Doctor"
      },
      {
        "command": "conflictcraft.scanWorkspaceConflicts",
        "title": "ConflictCraft: Scan Workspace Conflicts"
      },
      {
        "command": "conflictcraft.resolveGitUnmerged",
        "title": "ConflictCraft: Resolve Git Unmerged Files"
      },
      {
        "command": "conflictcraft.openFullTutorial",
        "title": "ConflictCraft: Open Full Tutorial"
      }
    ],
    "configuration": {
      "title": "ConflictCraft",
      "properties": {
        "conflictcraft.autoPrompt": {
          "type": "string",
          "enum": [
            "always",
            "once",
            "never"
          ],
          "default": "once",
          "description": "Controls automatic prompt behavior when conflict markers are detected."
        },
        "conflictcraft.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Python executable used by the bundled ConflictCraft rule engine."
        },
        "conflictcraft.enableSmartRules": {
          "type": "boolean",
          "default": true,
          "description": "Enable deterministic Python smart rules on top of core merge behavior."
        },
        "conflictcraft.showExplainMode": {
          "type": "boolean",
          "default": true,
          "description": "Show Explain Mode panel by default when opening ConflictCraft editor."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -w -p .",
    "test": "node -e \"console.log('No extension tests yet')\"",
    "package": "npx @vscode/vsce package --allow-missing-repository",
    "publish:patch": "npx @vscode/vsce publish patch --allow-missing-repository",
    "publish:minor": "npx @vscode/vsce publish minor --allow-missing-repository",
    "publish:major": "npx @vscode/vsce publish major --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.7.2"
  }
}
