{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conflictcraft.dev/schemas/analysis-result.schema.json",
  "title": "AnalysisResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "protocol_version",
    "file",
    "hunks",
    "graph",
    "analysis_required",
    "meta"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "protocol_version": { "type": "string" },
    "file": { "type": "string" },
    "encoding": { "type": "string" },
    "hunks": {
      "type": "array",
      "items": { "$ref": "hunk.schema.json" }
    },
    "graph": { "$ref": "graph.schema.json" },
    "analysis_required": { "type": "boolean" },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine_version", "generated_at"],
      "properties": {
        "engine_version": { "type": "string" },
        "generated_at": { "type": "string" }
      }
    }
  }
}
