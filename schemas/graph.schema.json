{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conflictcraft.dev/schemas/graph.schema.json",
  "title": "ConflictGraph",
  "type": "object",
  "additionalProperties": false,
  "required": ["nodes", "edges"],
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["node_id", "hunk_id", "category", "depends_on"],
        "properties": {
          "node_id": { "type": "string" },
          "hunk_id": { "type": "string" },
          "category": { "type": "string", "enum": ["conflict", "change", "context"] },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "reason"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "reason": {
            "type": "string",
            "enum": ["adjacent", "symbol_overlap", "ordering"]
          }
        }
      }
    }
  }
}
